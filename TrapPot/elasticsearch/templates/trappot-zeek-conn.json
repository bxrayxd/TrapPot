{
  "index_patterns": ["trappot-zeek-conn"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "conn_state": { "type": "keyword" },
        "duration": { "type": "float" },
        "id.orig_h": { "type": "ip" },
        "id.orig_p": { "type": "integer" },
        "id.resp_h": { "type": "ip" },
        "id.resp_p": { "type": "integer" },
        "orig_bytes": { "type": "integer" },
        "orig_ip_bytes": { "type": "integer" },
        "orig_pkts": { "type": "integer" },
        "proto": { "type": "keyword" },
        "resp_bytes": { "type": "integer" },
        "resp_ip_bytes": { "type": "integer" },
        "resp_pkts": { "type": "integer" },
        "service": { "type": "keyword" },
        "trappot_source": { "type": "keyword" },
        "uid": { "type": "keyword" },
        "geoip": {
          "properties": {
            "location": { "type": "geo_point" }
          }
        }
      }
    }
  }
}
