{
  "index_patterns": ["trappot-cowrie"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "eventid": { "type": "keyword" },
        "protocol": { "type": "keyword" },
        "session": { "type": "keyword" },
        "src_ip": { "type": "ip" },
        "trappot_source": { "type": "keyword" },
        "geoip": {
          "properties": {
            "location": { "type": "geo_point" }
          }
        }
      }
    }
  }
}
