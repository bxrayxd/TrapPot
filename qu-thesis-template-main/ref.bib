@ARTICLE{dekeersmaeker2023survey,
  author={De Keersmaeker, François and Cao, Yinan and Ndonda, Gorby Kabasele and Sadre, Ramin},
  journal={IEEE Communications Surveys \& Tutorials},
  title={A Survey of Public {IoT} Datasets for Network Security Research},
  year={2023},
  volume={25},
  number={3},
  pages={1808-1840},
  abstract={Publicly available datasets are an indispensable tool for researchers, as they allow testing new algorithms on a wide range of different scenarios and making scientific experiments verifiable and reproducible. Research in IoT security is no exception. In particular, the design of traffic classification and intrusion detection solutions for network security relies on network traces obtained from real networks or realistic testbeds. In this paper, we provide a detailed survey on the existing datasets containing IoT network traffic. We classify them according to several features that help researchers quickly find the datasets that fit their specific needs. In total, we survey 74 datasets that we found by analyzing more than 100 scientific articles. We also discuss the weaknesses of existing datasets, identify challenges, and point to future directions for creating new IoT datasets.},
  keywords={Internet of Things;Protocols;Surveys;Telecommunication traffic;Servers;Network security;Internet;IoT;network;security;datasets;taxonomy;traf16 fic generation},
